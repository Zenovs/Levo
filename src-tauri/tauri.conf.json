{
  "productName": "Levo",
  "version": "0.1.0",
  "identifier": "com.levo.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "Levo",
        "width": 1200,
        "height": 760,
        "minWidth": 960,
        "minHeight": 620,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "center": true,
        "shadow": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [],
    "resources": {
      "binaries/*": "binaries/"
    },
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      },
      "wix": {
        "componentRefs": []
      }
    },
    "linux": {
      "deb": {
        "depends": ["ffmpeg", "libwebkit2gtk-4.1-0"]
      },
      "appimage": {
        "bundleMediaFramework": true
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15",
      "frameworks": []
    },
    "updater": {
      "active": true,
      "pubkey": "",
      "endpoints": [
        "https://github.com/Zenovs/Levo/releases/latest/download/latest.json"
      ]
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "",
      "endpoints": [
        "https://github.com/Zenovs/Levo/releases/latest/download/latest.json"
      ]
    }
  }
}
